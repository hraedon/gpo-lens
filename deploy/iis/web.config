<?xml version="1.0" encoding="utf-8"?>
<!--
  gpo-lens on IIS via HttpPlatformHandler (recommended).

  IIS launches and supervises uvicorn (via the gpo-lens entrypoint) as a child
  of the application pool and proxies all requests to it over a loopback port
  that IIS chooses (%HTTP_PLATFORM_PORT%). No third-party service wrapper is
  required — the Microsoft-signed HttpPlatformHandler module is the only
  prerequisite. See README.md in this directory for full setup, and especially
  the "Access control" section: gpo-lens has no per-user login, so the IIS site
  must be access-restricted.

  Place this file in the IIS site's physical path (e.g. C:\inetpub\gpo-lens).
  The application code itself lives in the virtualenv created by
  scripts\install-windows.ps1 (default C:\ProgramData\gpo-lens\venv).
-->
<configuration>
  <system.webServer>
    <handlers>
      <!-- Hand every request to the Python process. -->
      <add name="httpPlatformHandler"
           path="*"
           verb="*"
           modules="httpPlatformHandler"
           resourceType="Unspecified" />
    </handlers>

    <!-- Launch the gpo-lens web UI. The global db flag (passed before the
         "serve" subcommand) pins the SQLite estate to an absolute path under
         the data dir, because the app pool working directory is not the repo.
         The app creates the DB on first run if it is missing. Binding to
         loopback means no auth token is required to start; IIS terminates TLS
         and proxies to it. -->
    <httpPlatform processPath="C:\ProgramData\gpo-lens\venv\Scripts\python.exe"
                  arguments="-m gpo_lens --db C:\ProgramData\gpo-lens\gpo-lens.sqlite3 serve --host 127.0.0.1 --port %HTTP_PLATFORM_PORT%"
                  stdoutLogEnabled="true"
                  stdoutLogFile="C:\ProgramData\gpo-lens\logs\stdout"
                  startupTimeLimit="60"
                  startupRetryCount="3"
                  requestTimeout="00:04:00">
      <environmentVariables>
        <!-- Optional: AI narration for the Ask page. Leave unset to keep the
             deterministic core only (the Ask page shows a "not configured"
             notice).
        <environmentVariable name="GPO_LENS_LLM_ENDPOINT" value="https://llm.example.com/v1/chat/completions" />
        <environmentVariable name="GPO_LENS_API_KEY" value="..." />
        -->
        <!-- Access control note: behind IIS every request arrives from
             127.0.0.1, so gpo-lens treats all callers as the trusted local
             analyst (view + ingest + narrate). Setting GPO_LENS_AUTH_TOKEN here
             would require a Bearer header that a browser cannot send, breaking
             the UI — so restrict access at the IIS layer instead (see README
             "Access control"), or keep this site on an isolated network. -->
      </environmentVariables>
    </httpPlatform>

    <!-- Don't advertise the IIS/Python stack, and allow large estate
         uploads. IIS's default maxAllowedContentLength is 30 MB (30000000),
         which rejects real collector exports — a medium estate ZIP is commonly
         50–100+ MB. 524288000 (500 MB) matches the app-level limit (_MAX_UPLOAD_BYTES in web/app.py), so IIS never
         refuses a request the app would accept. -->
    <security>
      <requestFiltering removeServerHeader="true">
        <requestLimits maxAllowedContentLength="524288000" />
      </requestFiltering>
    </security>

    <!-- HSTS when IIS is the TLS terminator. -->
    <httpProtocol>
      <customHeaders>
        <add name="Strict-Transport-Security" value="max-age=31536000; includeSubDomains" />
      </customHeaders>
    </httpProtocol>
  </system.webServer>
</configuration>
